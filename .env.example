# --- Slack (Socket Mode) ---
# https://api.slack.com/apps で App を作って取得する。
# bot token は xoxb- で始まる。Bot User OAuth Token。
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
# app-level token は xapp- で始まる。Socket Mode 用、scope=connections:write。
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Webhook (iOS ショートカット用) ---
# Apple Watch のショートカットから POST するときの Bearer トークン。openssl rand -hex 32 などで生成。
WEBHOOK_TOKEN=replace-me-with-a-random-secret
# 0.0.0.0 で listen するポート。Tailscale/VPN 経由で叩く想定。
WEBHOOK_PORT=8787

# --- Claude ---
# 呼び出すコマンド。フルパスでも可。
CLAUDE_CMD=claude
# 追加引数。ヘッドレス用途では --dangerously-skip-permissions を付けないと permission prompt で詰まる。
CLAUDE_EXTRA_ARGS=--dangerously-skip-permissions
# 1 リクエストの最大秒数。
CLAUDE_TIMEOUT_SEC=120

# --- 動作 ---
# DEBUG=1 にすると claude を呼ばずに echo っぽい応答を返す（手元検証用）。
CLAUDE_WATCH_DEBUG=0
