# --- Discord ---
# https://discord.com/developers/applications で App を作成し Bot タブでトークンを取得する。
# Bot タブの "Privileged Gateway Intents" で MESSAGE CONTENT INTENT を必ず ON にする。
DISCORD_BOT_TOKEN=your-discord-bot-token

# --- チャンネル ↔ 対話セッション対応表 (Phase 2, ADR-002: send-keys 入力 + JSONL tail) ---
# 複数プロジェクトをチャンネルごとに使い分けたい場合は claude-watch.toml (TOML) を使う。
# cp claude-watch.toml.example claude-watch.toml で作成し、[[projects]] に
# channel_id / tmux_target / cwd を並べる。CLAUDE_WATCH_CONFIG が指すファイルが
# 存在すればそちらが優先され、DISCORD_CHANNEL_ID 系の env fallback は無視される。
CLAUDE_WATCH_CONFIG=claude-watch.toml

# claude-watch.toml を使わない場合の後方互換 (単一チャンネルのみ)。
# 監視対象の専用チャンネル ID (整数)。Discord クライアントで開発者モードを ON にし、
# チャンネルを右クリック → 「ID をコピー」で取得する。このチャンネル内の全メッセージが
# DISCORD_TMUX_TARGET の tmux pane へ send-keys 入力される（bot 自身のメッセージは無視）。
# DISCORD_TMUX_TARGET は必須 (ADR-002 の send-keys 方式では対象 tmux pane の指定が
# 原理的に必須なため、未設定は起動時に ValueError で fail-fast)。
# `session:window.pane` 形式。対象セッションの pane で
# `tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}'` を実行すると取得できる。
DISCORD_CHANNEL_ID=000000000000000000
DISCORD_TMUX_TARGET=main:0.0
# セッション JSONL 特定用の作業ディレクトリ（対象 pane のカレントディレクトリと一致させる）。
# 未設定時はプロセスの作業ディレクトリが使われ、起動時に warning ログが出る。
DISCORD_CHANNEL_DIR=/home/shohei/プロジェクト/applewatch

# JSONL tail で応答 (stop_reason == "end_turn") を待つ最大秒数。
CLAUDE_WATCH_REPLY_TIMEOUT_SEC=180

# --- Webhook (iOS ショートカット用) ---
# Apple Watch のショートカットから POST するときの Bearer トークン。openssl rand -hex 32 などで生成。
WEBHOOK_TOKEN=replace-me-with-a-random-secret
# 0.0.0.0 で listen するポート。Tailscale/VPN 経由で叩く想定。
WEBHOOK_PORT=8787

# --- Claude (`-p` ヘッドレス経路。webhook /ask 専用。Discord bot は Phase 2 から
#     send-keys + JSONL tail に切り替わったためここには使わない。ADR-002 参照) ---
# 呼び出すコマンド。フルパスでも可。
CLAUDE_CMD=claude
# 追加引数。ヘッドレス用途では --dangerously-skip-permissions を付けないと permission prompt で詰まる。
CLAUDE_EXTRA_ARGS=--dangerously-skip-permissions
# 1 リクエストの最大秒数。
CLAUDE_TIMEOUT_SEC=120

# --- 動作 ---
# DEBUG=1 にすると claude を呼ばずに echo っぽい応答を返す（手元検証用。webhook /ask のみ対象）。
CLAUDE_WATCH_DEBUG=0
